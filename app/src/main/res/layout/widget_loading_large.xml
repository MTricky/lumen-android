<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/near_black"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top: badge skeleton -->
    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="28dp"
        android:background="@drawable/widget_skeleton_badge_preview" />

    <!-- Center: skeleton text lines -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:background="@drawable/widget_skeleton_line" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="10dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:background="@drawable/widget_skeleton_line" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="10dp" />

        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="20dp"
            android:background="@drawable/widget_skeleton_line" />
    </LinearLayout>

    <!-- Bottom: reference badge right-aligned -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end">

        <FrameLayout
            android:layout_width="75dp"
            android:layout_height="24dp"
            android:background="@drawable/widget_ref_bg" />
    </LinearLayout>
</LinearLayout>
