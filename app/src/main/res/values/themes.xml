<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Lumen" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/near_black</item>
        <item name="colorPrimaryVariant">@color/near_black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/near_black</item>
        <item name="colorSecondaryVariant">@color/near_black</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/near_black</item>
        <item name="android:navigationBarColor">@color/near_black</item>
        <item name="android:windowBackground">@color/near_black</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.Lumen.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/near_black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/near_black</item>
        <item name="postSplashScreenTheme">@style/Theme.Lumen</item>
    </style>
</resources>
