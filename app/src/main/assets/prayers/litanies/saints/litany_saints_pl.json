{
  "id": "saints",
  "title": "Litania do Wszystkich Świętych",
  "subtitle": "Wielka modlitwa wstawiennicza Kościoła",
  "prayers": {
    "signOfTheCross": {
      "title": "Znak Krzyża",
      "text": "W imię Ojca i Syna, i Ducha Świętego. Amen."
    },
    "closingPrayer": {
      "title": "Modlitwa",
      "text": "Boże, którego chwałę głoszą błogosławieni mieszkańcy nieba, daj, prosimy, abyśmy za wstawiennictwem wszystkich Twoich Świętych dostąpili Twojego obfitego miłosierdzia. Przez Chrystusa, Pana naszego. Amen."
    }
  },
