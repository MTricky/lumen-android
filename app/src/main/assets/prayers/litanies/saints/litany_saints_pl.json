    {
      "title": "Wybawienie",
      "type": "petition",
      "response": "wybaw nas, Panie.",
      "invocations": [
        { "text": "Od wszelkiego zła," },
        { "text": "Od każdego grzechu," },
        { "text": "Od gniewu Twego," },
        { "text": "Od nagłej i niespodziewanej śmierci," },
        { "text": "Od sideł szatańskich," },
        { "text": "Od gniewu, nienawiści i wszelkiej złej woli," },
        { "text": "Od ducha nieczystości," },
        { "text": "Od gromu i burzy," },
        { "text": "Od klęski trzęsienia ziemi," },
        { "text": "Od zarazy, głodu i wojny," },
        { "text": "Od śmierci wiecznej," }
      ]
    },
    {
      "title": "Przez tajemnice Chrystusa",
      "type": "petition",
      "response": "wybaw nas, Panie.",
      "invocations": [
        { "text": "Przez tajemnicę świętego Wcielenia Twego," },
        { "text": "Przez Przyjście Twoje," },
        { "text": "Przez Narodzenie Twoje," },
        { "text": "Przez Chrzest i święty post Twój," },
        { "text": "Przez Krzyż i Mękę Twoją," },
        { "text": "Przez Śmierć i Pogrzeb Twój," },
        { "text": "Przez święte Zmartwychwstanie Twoje," },
        { "text": "Przez cudowne Wniebowstąpienie Twoje," },
        { "text": "Przez Zesłanie Ducha Świętego, Pocieszyciela," },
        { "text": "W dzień sądu," }
      ]
    },
    {
      "title": "Prośby",
      "type": "petition",
      "response": "prosimy Cię, wysłuchaj nas.",
      "invocations": [
        { "text": "Abyś nam odpuścić raczył," },
        { "text": "Abyś nam przebaczył," },
        { "text": "Abyś nas do prawdziwej pokuty doprowadzić raczył," },
        { "text": "Abyś Kościół swój święty rządzić i zachować raczył," },
        { "text": "Abyś Ojca Świętego i wszystkie stany kościelne w świętej pobożności zachować raczył," },
        { "text": "Abyś nieprzyjaciół Kościoła świętego ukorzyć raczył," },
        { "text": "Abyś królom i książętom chrześcijańskim pokój i zgodę prawdziwą dać raczył," },
        { "text": "Abyś całemu ludowi chrześcijańskiemu pokój i jedność dać raczył," },
        { "text": "Abyś wszystkich błądzących do jedności Kościoła doprowadzić raczył," },
        { "text": "Abyś wszystkich niewierzących światłem Ewangelii oświecić raczył," },
        { "text": "Abyś nas w świętej służbie Twojej utwierdzić i zachować raczył," },
        { "text": "Abyś umysły nasze ku pragnieniu rzeczy niebieskich podnieść raczył," },
        { "text": "Abyś wszystkim dobrodziejom naszym wieczne dobra oddać raczył," },
        { "text": "Abyś dusze nasze i braci naszych od wiecznego potępienia zachować raczył," },
        { "text": "Abyś urodzaje ziemskie dać i zachować raczył," },
        { "text": "Abyś wszystkim wiernym zmarłym wieczny odpoczynek dać raczył," },
        { "text": "Abyś nas wysłuchać raczył," },
        { "text": "Synu Boży," }
      ]
    },
    {
      "title": "Baranek Boży",
      "type": "lambOfGod",
