      "invocations": [
        { "text": "Señor, ten piedad de nosotros.", "response": "Señor, ten piedad de nosotros." },
        { "text": "Cristo, ten piedad de nosotros.", "response": "Cristo, ten piedad de nosotros." },
        { "text": "Señor, ten piedad de nosotros.", "response": "Señor, ten piedad de nosotros." },
        { "text": "Cristo, óyenos.", "response": "Cristo, escúchanos." }
      ]
    },
