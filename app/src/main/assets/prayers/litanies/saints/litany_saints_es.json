{
  "id": "saints",
  "title": "Letanía de los Santos",
  "subtitle": "La Gran Intercesión de la Iglesia",
  "prayers": {
    "signOfTheCross": {
      "title": "Señal de la Cruz",
      "text": "En el nombre del Padre, y del Hijo, y del Espíritu Santo. Amén."
    },
    "closingPrayer": {
      "title": "Oración",
      "text": "Oh Dios, cuya gloria proclaman los bienaventurados del cielo, concédenos, te rogamos, que por la intercesión de todos tus Santos, obtengamos tu abundante misericordia. Por Cristo nuestro Señor. Amén."
    }
  },
