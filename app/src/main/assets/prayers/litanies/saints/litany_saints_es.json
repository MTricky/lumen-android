    {
      "title": "Liberación",
      "type": "petition",
      "response": "líbranos, Señor.",
      "invocations": [
        { "text": "De todo mal," },
        { "text": "De todo pecado," },
        { "text": "De tu ira," },
        { "text": "De la muerte repentina e imprevista," },
        { "text": "De las asechanzas del demonio," },
        { "text": "De la ira, el odio y toda mala voluntad," },
        { "text": "Del espíritu de fornicación," },
        { "text": "Del rayo y la tempestad," },
        { "text": "Del azote del terremoto," },
        { "text": "De la peste, el hambre y la guerra," },
        { "text": "De la muerte eterna," }
      ]
    },
    {
      "title": "Por los Misterios de Cristo",
      "type": "petition",
      "response": "líbranos, Señor.",
      "invocations": [
        { "text": "Por el misterio de tu santa Encarnación," },
        { "text": "Por tu Venida," },
        { "text": "Por tu Nacimiento," },
        { "text": "Por tu Bautismo y santo ayuno," },
        { "text": "Por tu Cruz y Pasión," },
        { "text": "Por tu Muerte y Sepultura," },
        { "text": "Por tu santa Resurrección," },
        { "text": "Por tu admirable Ascensión," },
        { "text": "Por la venida del Espíritu Santo Paráclito," },
        { "text": "En el día del juicio," }
      ]
    },
    {
      "title": "Súplicas",
      "type": "petition",
      "response": "te rogamos, óyenos.",
      "invocations": [
        { "text": "Que nos perdones," },
        { "text": "Que nos indultes," },
        { "text": "Que nos lleves a verdadera penitencia," },
        { "text": "Que gobiernes y conserves tu santa Iglesia," },
        { "text": "Que conserves al Santo Padre y a todos los órdenes de la Iglesia en santa religión," },
        { "text": "Que humilles a los enemigos de la santa Iglesia," },
        { "text": "Que des paz y verdadera concordia a los reyes y príncipes cristianos," },
        { "text": "Que concedas la paz y la unidad a todo el pueblo cristiano," },
        { "text": "Que vuelvas a la unidad de la Iglesia a todos los que se han apartado de la verdad," },
        { "text": "Que lleves a todos los infieles a la luz del Evangelio," },
        { "text": "Que nos fortalezcas y conserves en tu santo servicio," },
        { "text": "Que eleves nuestras mentes a deseos celestiales," },
        { "text": "Que retribuyas con bienes eternos a todos nuestros bienhechores," },
        { "text": "Que libres nuestras almas y las de nuestros hermanos de la condenación eterna," },
        { "text": "Que des y conserves los frutos de la tierra," },
        { "text": "Que concedas el descanso eterno a todos los fieles difuntos," },
        { "text": "Que te dignes escucharnos," },
        { "text": "Hijo de Dios," }
      ]
    },
    {
      "title": "Cordero de Dios",
      "type": "lambOfGod",
      "invocations": [
        { "text": "Cordero de Dios, que quitas los pecados del mundo,", "response": "perdónanos, Señor." },
        { "text": "Cordero de Dios, que quitas los pecados del mundo,", "response": "escúchanos, Señor." },
        { "text": "Cordero de Dios, que quitas los pecados del mundo,", "response": "ten piedad de nosotros." }
