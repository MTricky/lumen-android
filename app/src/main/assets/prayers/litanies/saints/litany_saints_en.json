{
  "id": "saints",
  "title": "Litany of the Saints",
  "subtitle": "The Great Intercession of the Church",
  "prayers": {
    "signOfTheCross": {
      "title": "Sign of the Cross",
      "text": "In the name of the Father, and of the Son, and of the Holy Spirit. Amen."
    },
    "closingPrayer": {
      "title": "Closing Prayer",
      "text": "O God, whose glory the blessed citizens of heaven proclaim, grant, we pray, that through the intercession of all your Saints, we may obtain your abundant mercy. Through Christ our Lord. Amen."
    }
  },
  "sections": [
    {
