      "type": "kyrie",
      "invocations": [
        {
          "text": "Lord, have mercy.",
          "response": "Lord, have mercy."
        },
        {
          "text": "Christ, have mercy.",
          "response": "Christ, have mercy."
        },
        {
          "text": "Lord, have mercy.",
          "response": "Lord, have mercy."
        },
        {
          "text": "Christ, hear us.",
          "response": "Christ, graciously hear us."
        }
      ]
    },
    {
