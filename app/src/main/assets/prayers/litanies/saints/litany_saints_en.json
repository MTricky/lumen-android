    {
      "title": "Mercy",
      "type": "propitius",
      "invocations": [
        {
          "text": "Be merciful,",
          "response": "spare us, O Lord."
        },
        {
          "text": "Be merciful,",
          "response": "graciously hear us, O Lord."
        }
      ]
    },
    {
      "title": "Deliverance",
      "type": "petition",
      "response": "deliver us, O Lord.",
      "invocations": [
        {
          "text": "From all evil,"
        },
        {
          "text": "From all sin,"
        },
        {
          "text": "From your wrath,"
        },
        {
          "text": "From sudden and unprovided death,"
        },
        {
          "text": "From the snares of the devil,"
        },
        {
          "text": "From anger, hatred, and all ill will,"
        },
        {
          "text": "From the spirit of fornication,"
        },
        {
          "text": "From lightning and tempest,"
        },
        {
          "text": "From the scourge of earthquake,"
        },
        {
          "text": "From plague, famine, and war,"
        },
        {
          "text": "From everlasting death,"
        }
      ]
    },
    {
      "title": "By the Mysteries of Christ",
      "type": "petition",
      "response": "deliver us, O Lord.",
      "invocations": [
        {
          "text": "By the mystery of your holy Incarnation,"
        },
        {
          "text": "By your coming,"
        },
        {
          "text": "By your Nativity,"
        },
        {
          "text": "By your Baptism and holy fasting,"
        },
        {
          "text": "By your Cross and Passion,"
        },
        {
          "text": "By your Death and Burial,"
        },
        {
          "text": "By your holy Resurrection,"
        },
        {
          "text": "By your admirable Ascension,"
        },
        {
          "text": "By the coming of the Holy Spirit, the Paraclete,"
        },
        {
          "text": "On the day of judgment,"
        }
      ]
    },
    {
      "title": "Petitions",
      "type": "petition",
      "response": "we beseech thee, hear us.",
      "invocations": [
        {
          "text": "That you would spare us,"
        },
        {
          "text": "That you would pardon us,"
        },
        {
          "text": "That you would bring us to true penance,"
        },
        {
          "text": "That you would govern and preserve your holy Church,"
        },
        {
          "text": "That you would preserve our Holy Father and all orders of the Church in holy religion,"
        },
        {
          "text": "That you would humble the enemies of holy Church,"
        },
        {
          "text": "That you would give peace and true concord to Christian kings and princes,"
        },
        {
          "text": "That you would grant peace and unity to the whole Christian world,"
        },
        {
          "text": "That you would restore to the unity of the Church all who have strayed from the truth,"
        },
        {
          "text": "That you would bring all unbelievers to the light of the Gospel,"
        },
        {
          "text": "That you would strengthen and preserve us in your holy service,"
        },
        {
          "text": "That you would lift up our minds to heavenly desires,"
        },
        {
          "text": "That you would render eternal blessings to all our benefactors,"
        },
        {
          "text": "That you would deliver our souls and the souls of our brethren from eternal damnation,"
        },
        {
          "text": "That you would give and preserve the fruits of the earth,"
        },
        {
          "text": "That you would grant eternal rest to all the faithful departed,"
        },
        {
          "text": "That you would graciously hear us,"
        },
        {
          "text": "Son of God,"
        }
      ]
    },
    {
      "title": "Lamb of God",
      "type": "lambOfGod",
      "invocations": [
        {
          "text": "Lamb of God, who takes away the sins of the world,",
          "response": "spare us, O Lord."
        },
        {
          "text": "Lamb of God, who takes away the sins of the world,",
          "response": "graciously hear us, O Lord."
        },
        {
          "text": "Lamb of God, who takes away the sins of the world,",
          "response": "have mercy on us."
        }
      ]
    },
