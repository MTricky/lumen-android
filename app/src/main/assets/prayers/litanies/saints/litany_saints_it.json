{
  "id": "saints",
  "title": "Litanie dei Santi",
  "subtitle": "La Grande Intercessione della Chiesa",
  "prayers": {
    "signOfTheCross": {
      "title": "Segno della Croce",
      "text": "Nel nome del Padre e del Figlio e dello Spirito Santo. Amen."
    },
    "closingPrayer": {
      "title": "Orazione",
      "text": "O Dio, la cui gloria proclamano i beati cittadini del cielo, concedici, ti preghiamo, di ottenere per l'intercessione di tutti i tuoi Santi la tua abbondante misericordia. Per Cristo nostro Signore. Amen."
    }
  },
  "sections": [
    {
      "title": "Kyrie",
      "type": "kyrie",
      "invocations": [
        { "text": "Signore, pietà.", "response": "Signore, pietà." },
        { "text": "Cristo, pietà.", "response": "Cristo, pietà." },
        { "text": "Signore, pietà.", "response": "Signore, pietà." },
        { "text": "Cristo, ascoltaci.", "response": "Cristo, esaudiscici." }
      ]
    },
    {
      "title": "Santissima Trinità",
      "type": "petition",
      "response": "abbi pietà di noi.",
      "invocations": [
        { "text": "Padre celeste, che sei Dio," },
        { "text": "Figlio, Redentore del mondo, che sei Dio," },
        { "text": "Spirito Santo, che sei Dio," },
        { "text": "Santa Trinità, unico Dio," }
      ]
    },
    {
