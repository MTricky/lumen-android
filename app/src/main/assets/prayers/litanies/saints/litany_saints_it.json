    {
      "title": "Siateci propizio",
      "type": "petition",
      "response": "",
      "invocations": [
        { "text": "Siateci propizio,", "response": "perdonateci, o Signore." },
        { "text": "Siateci propizio,", "response": "esauditeci, o Signore." }
      ]
    },
    {
      "title": "Liberazione",
      "type": "petition",
      "response": "liberaci, o Signore.",
      "invocations": [
        { "text": "Da ogni male," },
        { "text": "Da ogni peccato," },
        { "text": "Dalla tua ira," },
        { "text": "Dalla morte improvvisa e imprevista," },
        { "text": "Dalle insidie del demonio," },
        { "text": "Dall'ira, dall'odio e da ogni cattiva volontà," },
        { "text": "Dallo spirito di fornicazione," },
        { "text": "Dal fulmine e dalla tempesta," },
        { "text": "Dal flagello del terremoto," },
        { "text": "Dalla peste, dalla fame e dalla guerra," },
        { "text": "Dalla morte eterna," }
      ]
    },
    {
      "title": "Per i Misteri di Cristo",
      "type": "petition",
      "response": "liberaci, o Signore.",
      "invocations": [
        { "text": "Per il mistero della tua santa Incarnazione," },
        { "text": "Per la tua Venuta," },
        { "text": "Per la tua Natività," },
        { "text": "Per il tuo Battesimo e il tuo santo digiuno," },
        { "text": "Per la tua Croce e la tua Passione," },
        { "text": "Per la tua Morte e Sepoltura," },
        { "text": "Per la tua santa Risurrezione," },
        { "text": "Per la tua mirabile Ascensione," },
        { "text": "Per la venuta dello Spirito Santo Paraclito," },
        { "text": "Nel giorno del giudizio," }
      ]
    },
    {
      "title": "Suppliche",
      "type": "petition",
      "response": "ti preghiamo, ascoltaci.",
      "invocations": [
        { "text": "Che ci perdoni," },
        { "text": "Che ci faccia grazia," },
        { "text": "Che ci conduca a vera penitenza," },
        { "text": "Che governi e conservi la tua santa Chiesa," },
        { "text": "Che conservi il Santo Padre e tutti gli ordini della Chiesa nella santa religione," },
        { "text": "Che umili i nemici della santa Chiesa," },
        { "text": "Che conceda la pace e la vera concordia ai re e ai principi cristiani," },
        { "text": "Che conceda la pace e l'unità a tutto il popolo cristiano," },
        { "text": "Che riconduca all'unità della Chiesa tutti coloro che si sono allontanati dalla verità," },
        { "text": "Che illumini con la luce del Vangelo tutti gli infedeli," },
        { "text": "Che ci rafforzi e ci conservi nel tuo santo servizio," },
        { "text": "Che innalzi le nostre menti ai desideri celesti," },
        { "text": "Che ricompensi con beni eterni tutti i nostri benefattori," },
        { "text": "Che liberi le nostre anime e quelle dei nostri fratelli dalla dannazione eterna," },
        { "text": "Che dia e conservi i frutti della terra," },
        { "text": "Che conceda il riposo eterno a tutti i fedeli defunti," },
        { "text": "Che ti degni di esaudirci," },
        { "text": "Figlio di Dio," }
      ]
    },
    {
      "title": "Agnello di Dio",
      "type": "lambOfGod",
      "invocations": [
        { "text": "Agnello di Dio, che togli i peccati del mondo,", "response": "perdonaci, o Signore." },
        { "text": "Agnello di Dio, che togli i peccati del mondo,", "response": "esaudiscici, o Signore." },
        { "text": "Agnello di Dio, che togli i peccati del mondo,", "response": "abbi pietà di noi." }
      ]
    },
    {
      "title": "Versetto",
      "type": "versicle",
      "invocations": [
        { "text": "Cristo, ascoltaci.", "response": "Cristo, esaudiscici." }
      ]
    }
  ]
