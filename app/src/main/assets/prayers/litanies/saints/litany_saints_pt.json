      "type": "petition",
      "response": "rogai por nós.",
      "invocations": [
        { "text": "São Miguel," },
        { "text": "São Gabriel," },
        { "text": "São Rafael," },
        { "text": "Todos os santos Anjos e Arcanjos," },
        { "text": "Todas as santas ordens de espíritos bem-aventurados," },
        { "text": "São João Batista," },
        { "text": "São José," },
        { "text": "Todos os santos Patriarcas e Profetas," }
      ]
    },
