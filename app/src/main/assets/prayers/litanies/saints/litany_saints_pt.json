{
  "id": "saints",
  "title": "Ladainha de Todos os Santos",
  "subtitle": "A Grande Intercessão da Igreja",
  "prayers": {
    "signOfTheCross": {
      "title": "Sinal da Cruz",
      "text": "Em nome do Pai, e do Filho, e do Espírito Santo. Amém."
    },
    "closingPrayer": {
      "title": "Oração",
      "text": "Ó Deus, cuja glória proclamam os bem-aventurados cidadãos do céu, concedei-nos, vos pedimos, que pela intercessão de todos os vossos Santos, alcancemos a vossa abundante misericórdia. Por Cristo nosso Senhor. Amém."
    }
  },
  "sections": [
    {
      "title": "Kyrie",
      "type": "kyrie",
      "invocations": [
        { "text": "Senhor, tende piedade de nós.", "response": "Senhor, tende piedade de nós." },
        { "text": "Cristo, tende piedade de nós.", "response": "Cristo, tende piedade de nós." },
        { "text": "Senhor, tende piedade de nós.", "response": "Senhor, tende piedade de nós." },
        { "text": "Cristo, ouvi-nos.", "response": "Cristo, atendei-nos." }
      ]
    },
    {
      "title": "Santíssima Trindade",
      "type": "petition",
      "response": "tende piedade de nós.",
      "invocations": [
        { "text": "Pai celeste, que sois Deus," },
        { "text": "Filho, Redentor do mundo, que sois Deus," },
        { "text": "Espírito Santo, que sois Deus," },
        { "text": "Santíssima Trindade, que sois um só Deus," }
      ]
    },
    {
      "title": "Santa Maria",
      "type": "petition",
      "response": "rogai por nós.",
      "invocations": [
        { "text": "Santa Maria," },
        { "text": "Santa Mãe de Deus," },
        { "text": "Santa Virgem das virgens," }
      ]
    },
    {
