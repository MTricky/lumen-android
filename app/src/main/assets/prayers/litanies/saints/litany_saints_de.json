{
  "id": "saints",
  "title": "Allerheiligenlitanei",
  "subtitle": "Die Große Fürbitte der Kirche",
  "prayers": {
    "signOfTheCross": {
      "title": "Kreuzzeichen",
      "text": "Im Namen des Vaters und des Sohnes und des Heiligen Geistes. Amen."
    },
    "closingPrayer": {
      "title": "Gebet",
      "text": "O Gott, dessen Herrlichkeit die seligen Bewohner des Himmels verkünden, gewähre uns, wir bitten dich, dass wir durch die Fürbitte aller deiner Heiligen dein reiches Erbarmen erlangen. Durch Christus, unseren Herrn. Amen."
    }
  },
  "sections": [
    {
      "title": "Kyrie",
      "type": "kyrie",
      "invocations": [
        {
          "text": "Herr, erbarme dich.",
          "response": "Herr, erbarme dich."
        },
        {
          "text": "Christus, erbarme dich.",
          "response": "Christus, erbarme dich."
        },
        {
          "text": "Herr, erbarme dich.",
          "response": "Herr, erbarme dich."
        },
        {
          "text": "Christus, höre uns.",
          "response": "Christus, erhöre uns."
        }
      ]
    },
