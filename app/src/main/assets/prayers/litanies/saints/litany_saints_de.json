    {
      "title": "Erbarmen",
      "type": "propitius",
      "invocations": [
        {
          "text": "Sei uns gnädig,",
          "response": "verschone uns, o Herr."
        },
        {
          "text": "Sei uns gnädig,",
          "response": "erhöre uns, o Herr."
        }
      ]
    },
    {
      "title": "Errettung",
      "type": "petition",
      "response": "erlöse uns, o Herr.",
      "invocations": [
        {
          "text": "Von allem Übel,"
        },
        {
          "text": "Von aller Sünde,"
        },
        {
          "text": "Von deinem Zorn,"
        },
        {
          "text": "Von einem plötzlichen und unvorhergesehenen Tod,"
        },
        {
          "text": "Von den Nachstellungen des Teufels,"
        },
        {
          "text": "Von Zorn, Hass und allem bösen Willen,"
        },
        {
          "text": "Vom Geist der Unreinheit,"
        },
        {
          "text": "Von Blitz und Unwetter,"
        },
        {
          "text": "Von der Geißel des Erdbebens,"
        },
        {
          "text": "Von Pest, Hunger und Krieg,"
        },
        {
          "text": "Vom ewigen Tod,"
        }
      ]
    },
    {
      "title": "Durch die Geheimnisse Christi",
      "type": "petition",
      "response": "erlöse uns, o Herr.",
      "invocations": [
        {
          "text": "Durch das Geheimnis deiner heiligen Menschwerdung,"
        },
        {
          "text": "Durch deine Ankunft,"
        },
        {
          "text": "Durch deine Geburt,"
        },
        {
          "text": "Durch deine Taufe und dein heiliges Fasten,"
        },
        {
          "text": "Durch dein Kreuz und Leiden,"
        },
        {
          "text": "Durch deinen Tod und dein Begräbnis,"
        },
        {
          "text": "Durch deine heilige Auferstehung,"
        },
        {
          "text": "Durch deine wunderbare Himmelfahrt,"
        },
        {
          "text": "Durch die Herabkunft des Heiligen Geistes, des Trösters,"
        },
        {
          "text": "Am Tag des Gerichtes,"
        }
      ]
    },
    {
      "title": "Bitten",
      "type": "petition",
      "response": "wir bitten dich, erhöre uns.",
      "invocations": [
        {
          "text": "Dass du uns verschonest,"
        },
        {
          "text": "Dass du uns verzeihest,"
        },
        {
          "text": "Dass du uns zu wahrer Buße führest,"
        },
        {
          "text": "Dass du deine heilige Kirche regieren und erhalten wollest,"
        },
        {
          "text": "Dass du den Heiligen Vater und alle Stände der Kirche in der heiligen Religion erhalten wollest,"
        },
        {
          "text": "Dass du die Feinde der heiligen Kirche demütigen wollest,"
        },
        {
          "text": "Dass du den christlichen Königen und Fürsten Frieden und wahre Eintracht geben wollest,"
        },
        {
          "text": "Dass du der ganzen Christenheit Frieden und Einheit verleihen wollest,"
        },
        {
          "text": "Dass du alle Irrenden zur Einheit der Kirche zurückführen wollest,"
        },
        {
          "text": "Dass du alle Ungläubigen mit dem Licht des Evangeliums erleuchten wollest,"
        },
        {
          "text": "Dass du uns in deinem heiligen Dienst stärken und bewahren wollest,"
        },
        {
          "text": "Dass du unseren Sinn zu himmlischem Verlangen erheben wollest,"
        },
        {
          "text": "Dass du allen unseren Wohltätern ewige Güter vergelten wollest,"
        },
        {
          "text": "Dass du unsere Seelen und die Seelen unserer Brüder von der ewigen Verdammnis erretten wollest,"
        },
        {
          "text": "Dass du die Früchte der Erde geben und erhalten wollest,"
        },
        {
          "text": "Dass du allen verstorbenen Gläubigen die ewige Ruhe geben wollest,"
        },
        {
          "text": "Dass du uns gnädig erhören wollest,"
        },
        {
          "text": "Sohn Gottes,"
        }
      ]
    },
    {
      "title": "Lamm Gottes",
      "type": "lambOfGod",
      "invocations": [
        {
          "text": "Lamm Gottes, du nimmst hinweg die Sünden der Welt,",
          "response": "verschone uns, o Herr."
        },
        {
          "text": "Lamm Gottes, du nimmst hinweg die Sünden der Welt,",
          "response": "erhöre uns, o Herr."
        },
        {
          "text": "Lamm Gottes, du nimmst hinweg die Sünden der Welt,",
          "response": "erbarme dich unser."
