    {
      "title": "Soyez-nous propice",
      "type": "petition",
      "response": "",
      "invocations": [
        { "text": "Soyez-nous propice,", "response": "pardonnez-nous, Seigneur." },
        { "text": "Soyez-nous propice,", "response": "exaucez-nous, Seigneur." }
      ]
    },
    {
      "title": "Délivrance",
      "type": "petition",
      "response": "délivrez-nous, Seigneur.",
      "invocations": [
        { "text": "De tout mal," },
        { "text": "De tout péché," },
        { "text": "De votre colère," },
        { "text": "De la mort subite et imprévue," },
        { "text": "Des embûches du démon," },
        { "text": "De la colère, de la haine et de toute mauvaise volonté," },
        { "text": "De l'esprit de fornication," },
        { "text": "De la foudre et de la tempête," },
        { "text": "Du fléau du tremblement de terre," },
        { "text": "De la peste, de la famine et de la guerre," },
        { "text": "De la mort éternelle," }
      ]
    },
    {
      "title": "Par les Mystères du Christ",
      "type": "petition",
      "response": "délivrez-nous, Seigneur.",
      "invocations": [
        { "text": "Par le mystère de votre sainte Incarnation," },
        { "text": "Par votre Avènement," },
        { "text": "Par votre Nativité," },
        { "text": "Par votre Baptême et votre saint jeûne," },
        { "text": "Par votre Croix et votre Passion," },
        { "text": "Par votre Mort et votre Sépulture," },
        { "text": "Par votre sainte Résurrection," },
        { "text": "Par votre admirable Ascension," },
        { "text": "Par la venue du Saint-Esprit Consolateur," },
        { "text": "Au jour du jugement," }
      ]
    },
    {
      "title": "Supplications",
      "type": "petition",
      "response": "nous vous en prions, écoutez-nous.",
      "invocations": [
        { "text": "De nous pardonner," },
        { "text": "De nous faire grâce," },
        { "text": "De nous conduire à une vraie pénitence," },
        { "text": "De gouverner et de conserver votre sainte Église," },
        { "text": "De conserver le Saint-Père et tous les ordres de l'Église dans la sainte religion," },
        { "text": "D'humilier les ennemis de la sainte Église," },
        { "text": "De donner la paix et la vraie concorde aux rois et aux princes chrétiens," },
        { "text": "D'accorder la paix et l'unité à tout le peuple chrétien," },
        { "text": "De ramener à l'unité de l'Église tous ceux qui se sont égarés de la vérité," },
        { "text": "D'éclairer de la lumière de l'Évangile tous les infidèles," },
        { "text": "De nous fortifier et de nous conserver dans votre saint service," },
        { "text": "D'élever nos esprits vers les désirs célestes," },
        { "text": "De rendre les biens éternels à tous nos bienfaiteurs," },
        { "text": "De délivrer nos âmes et celles de nos frères de la damnation éternelle," },
        { "text": "De donner et de conserver les fruits de la terre," },
        { "text": "D'accorder le repos éternel à tous les fidèles défunts," },
        { "text": "De daigner nous exaucer," },
        { "text": "Fils de Dieu," }
      ]
    },
    {
      "title": "Agneau de Dieu",
      "type": "lambOfGod",
      "invocations": [
        { "text": "Agneau de Dieu, qui effacez les péchés du monde,", "response": "pardonnez-nous, Seigneur." },
        { "text": "Agneau de Dieu, qui effacez les péchés du monde,", "response": "exaucez-nous, Seigneur." },
        { "text": "Agneau de Dieu, qui effacez les péchés du monde,", "response": "ayez pitié de nous." }
      ]
    },
