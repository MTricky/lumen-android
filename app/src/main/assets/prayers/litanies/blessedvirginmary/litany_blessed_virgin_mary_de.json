      "type": "petition",
      "response": "bitte für uns.",
      "invocations": [
        { "text": "Mutter Christi," },
        { "text": "Mutter der Kirche," },
        { "text": "Mutter der Barmherzigkeit," },
        { "text": "Mutter der göttlichen Gnade," },
        { "text": "Mutter der Hoffnung," },
        { "text": "Du reinste Mutter," },
        { "text": "Du keuscheste Mutter," },
        { "text": "Du unversehrte Mutter," },
        { "text": "Du unbefleckte Mutter," },
        { "text": "Du liebenswürdige Mutter," },
        { "text": "Du wunderbare Mutter," },
        { "text": "Du Mutter des guten Rates," },
        { "text": "Du Mutter des Schöpfers," },
        { "text": "Du Mutter des Erlösers," }
      ]
    },
    {
      "title": "Jungfrau",
      "type": "petition",
      "response": "bitte für uns.",
      "invocations": [
        { "text": "Du weiseste Jungfrau," },
        { "text": "Du ehrwürdige Jungfrau," },
        { "text": "Du lobwürdige Jungfrau," },
        { "text": "Du mächtige Jungfrau," },
        { "text": "Du gütige Jungfrau," },
        { "text": "Du getreue Jungfrau," }
      ]
    },
    {
      "title": "Symbolische Titel",
      "type": "petition",
      "response": "bitte für uns.",
      "invocations": [
        { "text": "Du Spiegel der Gerechtigkeit," },
        { "text": "Du Sitz der Weisheit," },
        { "text": "Du Ursache unserer Freude," },
        { "text": "Du geistliches Gefäß," },
        { "text": "Du ehrwürdiges Gefäß," },
        { "text": "Du ausgezeichnetes Gefäß der Andacht," },
        { "text": "Du geheimnisvolle Rose," },
        { "text": "Du Turm Davids," },
        { "text": "Du elfenbeinerner Turm," },
        { "text": "Du goldenes Haus," },
        { "text": "Du Bundeslade," },
        { "text": "Du Pforte des Himmels," },
        { "text": "Du Morgenstern," },
        { "text": "Du Heil der Kranken," },
        { "text": "Du Zuflucht der Sünder," },
        { "text": "Du Trost der Migranten," },
        { "text": "Du Trösterin der Betrübten," },
        { "text": "Du Hilfe der Christen," }
      ]
    },
    {
      "title": "Königin",
      "type": "petition",
      "response": "bitte für uns.",
      "invocations": [
        { "text": "Du Königin der Engel," },
        { "text": "Du Königin der Patriarchen," },
        { "text": "Du Königin der Propheten," },
        { "text": "Du Königin der Apostel," },
        { "text": "Du Königin der Märtyrer," },
        { "text": "Du Königin der Bekenner," },
        { "text": "Du Königin der Jungfrauen," },
        { "text": "Du Königin aller Heiligen," },
