{
  "id": "blessedVirginMary",
  "title": "Lauretanische Litanei",
  "subtitle": "Litanei von Loreto",
  "prayers": {
    "signOfTheCross": {
      "title": "Kreuzzeichen",
      "text": "Im Namen des Vaters und des Sohnes und des Heiligen Geistes. Amen."
    },
    "closingPrayer": {
      "title": "Gebet",
      "text": "Wir bitten dich, Herr, unser Gott: Gib uns, deinen Dienern, allzeit Gesundheit des Leibes und der Seele. Auf die Fürsprache der seligen, allzeit jungfräulichen Gottesmutter Maria befreie uns von allem Leid der Gegenwart und schenke uns die ewige Freude. Durch Christus, unseren Herrn. Amen."
    }
  },
  "sections": [
    {
      "title": "Kyrie",
      "type": "kyrie",
      "invocations": [
        { "text": "Herr, erbarme dich.", "response": "Herr, erbarme dich." },
        { "text": "Christus, erbarme dich.", "response": "Christus, erbarme dich." },
        { "text": "Herr, erbarme dich.", "response": "Herr, erbarme dich." },
        { "text": "Christus, höre uns.", "response": "Christus, erhöre uns." }
      ]
    },
    {
      "title": "Heilige Dreifaltigkeit",
      "type": "petition",
      "response": "erbarme dich unser.",
      "invocations": [
        { "text": "Gott Vater im Himmel," },
        { "text": "Gott Sohn, Erlöser der Welt," },
        { "text": "Gott Heiliger Geist," },
        { "text": "Heiligste Dreifaltigkeit, ein einiger Gott," }
      ]
    },
    {
      "title": "Heilige Maria",
      "type": "petition",
      "response": "bitte für uns.",
      "invocations": [
        { "text": "Heilige Maria," },
        { "text": "Heilige Gottesmutter," },
        { "text": "Heilige Jungfrau aller Jungfrauen," }
      ]
    },
    {
