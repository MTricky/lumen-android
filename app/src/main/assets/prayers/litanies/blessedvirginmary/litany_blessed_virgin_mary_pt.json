        { "text": "Cordeiro de Deus, que tirais o pecado do mundo,", "response": "ouvi-nos, Senhor." },
        { "text": "Cordeiro de Deus, que tirais o pecado do mundo,", "response": "tende piedade de nós." }
      ]
    },
    {
      "title": "Versículo",
      "type": "versicle",
      "invocations": [
