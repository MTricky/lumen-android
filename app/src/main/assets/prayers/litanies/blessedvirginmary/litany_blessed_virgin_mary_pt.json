{
  "id": "blessedVirginMary",
  "title": "Ladainha de Nossa Senhora",
  "subtitle": "Ladainha Lauretana",
  "prayers": {
    "signOfTheCross": {
      "title": "Sinal da Cruz",
      "text": "Em nome do Pai, e do Filho, e do Espírito Santo. Amém."
    },
    "closingPrayer": {
      "title": "Oração",
      "text": "Concedei-nos, Senhor Deus, a nós vossos servos, perpétua saúde de alma e de corpo, e pela gloriosa intercessão da bem-aventurada sempre Virgem Maria, sermos livres da tristeza presente e gozarmos da eterna alegria. Por Cristo nosso Senhor. Amém."
    }
  },
  "sections": [
    {
      "title": "Kyrie",
      "type": "kyrie",
      "invocations": [
        { "text": "Senhor, tende piedade de nós.", "response": "Senhor, tende piedade de nós." },
        { "text": "Cristo, tende piedade de nós.", "response": "Cristo, tende piedade de nós." },
        { "text": "Senhor, tende piedade de nós.", "response": "Senhor, tende piedade de nós." },
        { "text": "Cristo, ouvi-nos.", "response": "Cristo, atendei-nos." }
      ]
    },
    {
      "title": "Santíssima Trindade",
      "type": "petition",
      "response": "tende piedade de nós.",
      "invocations": [
        { "text": "Deus Pai do céu," },
        { "text": "Deus Filho, Redentor do mundo," },
        { "text": "Deus Espírito Santo," },
        { "text": "Santíssima Trindade, que sois um só Deus," }
      ]
    },
    {
