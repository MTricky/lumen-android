{
  "id": "blessedVirginMary",
  "title": "Litanies de la Sainte Vierge Marie",
  "subtitle": "Litanies de Lorette",
  "prayers": {
    "signOfTheCross": {
      "title": "Signe de Croix",
      "text": "Au nom du Père, et du Fils, et du Saint-Esprit. Amen."
    },
    "closingPrayer": {
      "title": "Oraison",
      "text": "Nous vous en supplions, Seigneur, accordez à vos serviteurs de jouir toujours de la santé de l'âme et du corps, et, par la glorieuse intercession de la bienheureuse Marie toujours Vierge, délivrez-nous des tristesses de la vie présente et donnez-nous d'avoir part aux joies éternelles. Par Jésus-Christ notre Seigneur. Amen."
    }
  },
  "sections": [
    {
      "title": "Kyrie",
      "type": "kyrie",
      "invocations": [
        { "text": "Seigneur, ayez pitié de nous.", "response": "Seigneur, ayez pitié de nous." },
        { "text": "Ô Christ, ayez pitié de nous.", "response": "Ô Christ, ayez pitié de nous." },
        { "text": "Seigneur, ayez pitié de nous.", "response": "Seigneur, ayez pitié de nous." },
        { "text": "Ô Christ, écoutez-nous.", "response": "Ô Christ, exaucez-nous." }
      ]
    },
    {
      "title": "Sainte Trinité",
      "type": "petition",
      "response": "ayez pitié de nous.",
      "invocations": [
        { "text": "Dieu le Père, du haut des cieux," },
        { "text": "Dieu le Fils, Rédempteur du monde," },
        { "text": "Dieu le Saint-Esprit," },
        { "text": "Trinité Sainte, qui êtes un seul Dieu," }
      ]
    },
