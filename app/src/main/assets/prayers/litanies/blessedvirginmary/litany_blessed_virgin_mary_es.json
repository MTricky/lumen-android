{
  "id": "blessedVirginMary",
  "title": "Letanía de la Santísima Virgen María",
  "subtitle": "Letanía Lauretana",
  "prayers": {
    "signOfTheCross": {
      "title": "Señal de la Cruz",
      "text": "En el nombre del Padre, y del Hijo, y del Espíritu Santo. Amén."
    },
    "closingPrayer": {
      "title": "Oración",
      "text": "Te rogamos nos concedas, Señor Dios nuestro, gozar de continua salud de alma y cuerpo, y por la gloriosa intercesión de la bienaventurada siempre Virgen María, vernos libres de las tristezas de la vida presente y disfrutar de las alegrías eternas. Por Jesucristo nuestro Señor. Amén."
    }
  },
  "sections": [
    {
      "title": "Kyrie",
      "type": "kyrie",
      "invocations": [
        { "text": "Señor, ten piedad.", "response": "Señor, ten piedad." },
        { "text": "Cristo, ten piedad.", "response": "Cristo, ten piedad." },
        { "text": "Señor, ten piedad.", "response": "Señor, ten piedad." },
        { "text": "Cristo, óyenos.", "response": "Cristo, escúchanos." }
      ]
    },
    {
      "title": "Santísima Trinidad",
      "type": "petition",
      "response": "ten piedad de nosotros.",
      "invocations": [
        { "text": "Dios, Padre celestial," },
        { "text": "Dios Hijo, Redentor del mundo," },
        { "text": "Dios, Espíritu Santo," },
        { "text": "Santísima Trinidad, un solo Dios," }
      ]
    },
    {
      "title": "Santa María",
      "type": "petition",
      "response": "ruega por nosotros.",
      "invocations": [
        { "text": "Santa María," },
        { "text": "Santa Madre de Dios," },
        { "text": "Santa Virgen de las vírgenes," }
      ]
    },
