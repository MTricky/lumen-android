        { "text": "Madre della Chiesa," },
        { "text": "Madre di misericordia," },
        { "text": "Madre della divina grazia," },
        { "text": "Madre della speranza," },
        { "text": "Madre purissima," },
        { "text": "Madre castissima," },
        { "text": "Madre sempre vergine," },
        { "text": "Madre immacolata," },
        { "text": "Madre degna d'amore," },
        { "text": "Madre ammirabile," },
        { "text": "Madre del buon consiglio," },
        { "text": "Madre del Creatore," },
        { "text": "Madre del Salvatore," }
      ]
    },
    {
      "title": "Vergine",
      "type": "petition",
      "response": "prega per noi.",
      "invocations": [
        { "text": "Vergine prudentissima," },
        { "text": "Vergine degna di onore," },
        { "text": "Vergine degna di lode," },
        { "text": "Vergine potente," },
        { "text": "Vergine clemente," },
        { "text": "Vergine fedele," }
      ]
    },
    {
      "title": "Titoli simbolici",
      "type": "petition",
      "response": "prega per noi.",
      "invocations": [
        { "text": "Specchio di giustizia," },
        { "text": "Sede della sapienza," },
        { "text": "Causa della nostra letizia," },
        { "text": "Vaso spirituale," },
        { "text": "Vaso degno di onore," },
        { "text": "Vaso insigne di devozione," },
        { "text": "Rosa mistica," },
        { "text": "Torre di Davide," },
        { "text": "Torre d'avorio," },
        { "text": "Casa d'oro," },
        { "text": "Arca dell'alleanza," },
        { "text": "Porta del cielo," },
        { "text": "Stella del mattino," },
        { "text": "Salute degli infermi," },
        { "text": "Rifugio dei peccatori," },
        { "text": "Conforto dei migranti," },
        { "text": "Consolatrice degli afflitti," },
        { "text": "Aiuto dei cristiani," }
      ]
    },
    {
      "title": "Regina",
      "type": "petition",
      "response": "prega per noi.",
      "invocations": [
        { "text": "Regina degli Angeli," },
        { "text": "Regina dei Patriarchi," },
        { "text": "Regina dei Profeti," },
        { "text": "Regina degli Apostoli," },
        { "text": "Regina dei Martiri," },
        { "text": "Regina dei Confessori," },
        { "text": "Regina delle Vergini," },
        { "text": "Regina di tutti i Santi," },
        { "text": "Regina concepita senza peccato originale," },
        { "text": "Regina assunta in cielo," },
        { "text": "Regina del santissimo Rosario," },
        { "text": "Regina della famiglia," },
        { "text": "Regina della pace," }
