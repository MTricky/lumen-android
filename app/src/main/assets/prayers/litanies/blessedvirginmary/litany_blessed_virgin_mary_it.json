    {
      "title": "Agnello di Dio",
      "type": "lambOfGod",
      "invocations": [
        { "text": "Agnello di Dio, che togli i peccati del mondo,", "response": "perdonaci, o Signore." },
        { "text": "Agnello di Dio, che togli i peccati del mondo,", "response": "esaudiscici, o Signore." },
        { "text": "Agnello di Dio, che togli i peccati del mondo,", "response": "abbi pietà di noi." }
      ]
    },
    {
      "title": "Versetto",
      "type": "versicle",
      "invocations": [
        { "text": "Prega per noi, Santa Madre di Dio.", "response": "Perché siamo resi degni delle promesse di Cristo." }
      ]
    }
  ]
