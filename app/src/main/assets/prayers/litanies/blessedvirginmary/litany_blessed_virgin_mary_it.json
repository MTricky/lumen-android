{
  "id": "blessedVirginMary",
  "title": "Litanie della Beata Vergine Maria",
  "subtitle": "Litanie Lauretane",
  "prayers": {
    "signOfTheCross": {
      "title": "Segno della Croce",
      "text": "Nel nome del Padre e del Figlio e dello Spirito Santo. Amen."
    },
    "closingPrayer": {
      "title": "Orazione",
      "text": "Concedi ai tuoi fedeli, Signore Dio nostro, di godere sempre la salute del corpo e dello spirito, e per la gloriosa intercessione della beata sempre Vergine Maria, liberaci dai mali presenti e guidaci alla gioia senza fine. Per Cristo nostro Signore. Amen."
    }
  },
  "sections": [
    {
      "title": "Kyrie",
      "type": "kyrie",
      "invocations": [
        { "text": "Signore, pietà.", "response": "Signore, pietà." },
        { "text": "Cristo, pietà.", "response": "Cristo, pietà." },
        { "text": "Signore, pietà.", "response": "Signore, pietà." },
        { "text": "Cristo, ascoltaci.", "response": "Cristo, esaudiscici." }
      ]
    },
    {
      "title": "Santissima Trinità",
      "type": "petition",
      "response": "abbi pietà di noi.",
      "invocations": [
        { "text": "Padre del cielo, che sei Dio," },
        { "text": "Figlio, Redentore del mondo, che sei Dio," },
        { "text": "Spirito Santo, che sei Dio," },
        { "text": "Santa Trinità, unico Dio," }
      ]
    },
    {
      "title": "Santa Maria",
      "type": "petition",
      "response": "prega per noi.",
      "invocations": [
        { "text": "Santa Maria," },
        { "text": "Santa Madre di Dio," },
        { "text": "Santa Vergine delle vergini," }
      ]
    },
    {
