{
  "id": "holyName",
  "title": "Letanía del Santísimo Nombre de Jesús",
  "subtitle": "En alabanza del Santísimo Nombre",
  "prayers": {
    "signOfTheCross": {
      "title": "Señal de la Cruz",
      "text": "En el nombre del Padre, y del Hijo, y del Espíritu Santo. Amén."
    },
    "closingPrayer": {
      "title": "Oración",
      "text": "Señor Jesucristo, que dijiste: «Pedid y recibiréis; buscad y hallaréis; llamad y se os abrirá», concédenos, te rogamos, el afecto de tu amor divino, para que te amemos con todo el corazón, en nuestras palabras y obras, y nunca cesemos de alabarte. Amén."
    }
  },
  "sections": [
    {
      "title": "Kyrie",
      "type": "kyrie",
      "invocations": [
        {
          "text": "Señor, ten piedad de nosotros.",
          "response": "Señor, ten piedad de nosotros."
        },
        {
          "text": "Cristo, ten piedad de nosotros.",
          "response": "Cristo, ten piedad de nosotros."
        },
        {
          "text": "Señor, ten piedad de nosotros.",
          "response": "Señor, ten piedad de nosotros."
        },
        {
          "text": "Jesús, óyenos.",
          "response": "Jesús, escúchanos."
        }
