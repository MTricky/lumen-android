    "signOfTheCross": {
      "title": "Signe de Croix",
      "text": "Au nom du Père, et du Fils, et du Saint-Esprit. Amen."
    },
    "closingPrayer": {
      "title": "Oraison",
      "text": "Seigneur Jésus-Christ, qui avez dit : « Demandez et vous recevrez ; cherchez et vous trouverez ; frappez et l'on vous ouvrira », daignez écouter nos supplications, et accordez-nous la grâce de votre divin amour, afin que nous vous aimions de tout notre cœur, dans toutes nos paroles et nos actions, et que nous ne cessions jamais de vous louer. Amen."
    }
  },
