        {
          "text": "Gesù, luce dei Confessori,"
        },
        {
          "text": "Gesù, purezza delle Vergini,"
        },
        {
          "text": "Gesù, corona di tutti i Santi,"
        }
      ]
    },
    {
      "title": "Misericordia",
      "type": "kyrie",
      "invocations": [
        {
          "text": "Siateci propizio,",
          "response": "perdonateci, o Gesù."
        },
        {
          "text": "Siateci propizio,",
          "response": "esauditeci, o Gesù."
        }
      ]
    },
    {
      "title": "Liberazione",
      "type": "petition",
      "response": "liberaci, o Gesù.",
      "invocations": [
        {
          "text": "Da ogni male,"
        },
        {
          "text": "Da ogni peccato,"
        },
        {
          "text": "Dalla tua ira,"
        },
        {
          "text": "Dalle insidie del demonio,"
        },
        {
          "text": "Dallo spirito di fornicazione,"
        },
        {
          "text": "Dalla morte eterna,"
        },
        {
          "text": "Dal disprezzo delle tue ispirazioni,"
        }
      ]
    },
    {
      "title": "Per i Misteri di Cristo",
      "type": "petition",
      "response": "liberaci, o Gesù.",
      "invocations": [
        {
          "text": "Per il mistero della tua santa Incarnazione,"
        },
        {
          "text": "Per la tua Natività,"
        },
        {
          "text": "Per la tua Infanzia,"
        },
        {
          "text": "Per la tua vita tutta divina,"
        },
        {
          "text": "Per le tue fatiche,"
        },
        {
          "text": "Per la tua agonia e Passione,"
        },
        {
          "text": "Per la tua Croce e il tuo abbandono,"
        },
        {
          "text": "Per i tuoi languori,"
        },
        {
          "text": "Per la tua Morte e Sepoltura,"
        },
        {
          "text": "Per la tua Risurrezione,"
        },
        {
          "text": "Per la tua Ascensione,"
        },
        {
          "text": "Per l'istituzione della Santissima Eucaristia,"
        },
        {
          "text": "Per le tue gioie,"
        },
        {
          "text": "Per la tua gloria,"
        }
      ]
    },
    {
      "title": "Agnello di Dio",
      "type": "lambOfGod",
      "invocations": [
        {
          "text": "Agnello di Dio, che togli i peccati del mondo,",
          "response": "perdonaci, o Gesù."
        },
        {
          "text": "Agnello di Dio, che togli i peccati del mondo,",
          "response": "esaudiscici, o Gesù."
        },
        {
          "text": "Agnello di Dio, che togli i peccati del mondo,",
          "response": "abbi pietà di noi."
        }
      ]
    },
    {
      "title": "Versetto",
      "type": "versicle",
      "invocations": [
        {
          "text": "Gesù, ascoltaci.",
          "response": "Gesù, esaudiscici."
        }
      ]
    }
  ]
