{
  "id": "holyName",
  "title": "Litanei vom Heiligsten Namen Jesu",
  "subtitle": "Zur Ehre des Heiligsten Namens",
  "prayers": {
    "signOfTheCross": {
      "title": "Kreuzzeichen",
      "text": "Im Namen des Vaters und des Sohnes und des Heiligen Geistes. Amen."
    },
    "closingPrayer": {
      "title": "Gebet",
      "text": "Herr Jesus Christus, du hast gesagt: «Bittet, und ihr werdet empfangen; suchet, und ihr werdet finden; klopfet an, und es wird euch aufgetan.» Erhöre gnädig unser Flehen und schenke uns die Gnade deiner göttlichen Liebe, damit wir dich von ganzem Herzen lieben, in all unseren Worten und Werken, und nie aufhören, dich zu loben. Amen."
    }
  },
  "sections": [
    {
      "title": "Kyrie",
      "type": "kyrie",
      "invocations": [
        {
          "text": "Herr, erbarme dich.",
          "response": "Herr, erbarme dich."
        },
        {
          "text": "Christus, erbarme dich.",
          "response": "Christus, erbarme dich."
        },
        {
          "text": "Herr, erbarme dich.",
          "response": "Herr, erbarme dich."
        },
        {
          "text": "Jesus, höre uns.",
          "response": "Jesus, erhöre uns."
        }
      ]
    },
    {
      "title": "Heilige Dreifaltigkeit",
      "type": "petition",
      "response": "erbarme dich unser.",
      "invocations": [
        {
          "text": "Gott Vater im Himmel,"
        },
        {
          "text": "Gott Sohn, Erlöser der Welt,"
        },
        {
          "text": "Gott Heiliger Geist,"
        },
        {
          "text": "Heiligste Dreifaltigkeit, ein einiger Gott,"
        }
      ]
    },
    {
      "title": "Göttliche Herrlichkeit",
      "type": "petition",
      "response": "erbarme dich unser.",
      "invocations": [
        {
          "text": "Jesus, Sohn des lebendigen Gottes,"
        },
        {
          "text": "Jesus, Abglanz des Vaters,"
