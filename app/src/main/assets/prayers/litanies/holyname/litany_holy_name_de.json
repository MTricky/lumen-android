        {
          "text": "Jesus, du Bewunderungswürdigster,"
        },
        {
          "text": "Jesus, du starker Gott,"
        },
        {
          "text": "Jesus, Vater der zukünftigen Welt,"
        },
        {
          "text": "Jesus, Engel des großen Ratschlusses,"
        },
        {
          "text": "Jesus, du Allmächtiger,"
        },
        {
          "text": "Jesus, du Geduldigster,"
        },
        {
          "text": "Jesus, du Gehorsamster,"
        },
        {
          "text": "Jesus, sanftmütig und demütig von Herzen,"
