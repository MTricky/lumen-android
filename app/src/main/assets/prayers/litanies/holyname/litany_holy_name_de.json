    {
      "title": "Lamm Gottes",
      "type": "lambOfGod",
      "invocations": [
        {
          "text": "Lamm Gottes, du nimmst hinweg die Sünden der Welt,",
          "response": "verschone uns, o Jesus."
        },
        {
          "text": "Lamm Gottes, du nimmst hinweg die Sünden der Welt,",
          "response": "erhöre uns, o Jesus."
        },
        {
          "text": "Lamm Gottes, du nimmst hinweg die Sünden der Welt,",
          "response": "erbarme dich unser."
        }
      ]
    },
    {
      "title": "Versikel",
      "type": "versicle",
      "invocations": [
        {
          "text": "Jesus, höre uns.",
          "response": "Jesus, erhöre uns."
        }
      ]
    }
  ]
