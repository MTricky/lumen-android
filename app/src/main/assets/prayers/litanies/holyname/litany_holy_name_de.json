    {
      "title": "Erbarmen",
      "type": "kyrie",
      "invocations": [
        {
          "text": "Sei uns gnädig,",
          "response": "verschone uns, o Jesus."
        },
        {
          "text": "Sei uns gnädig,",
          "response": "erhöre uns, o Jesus."
        }
      ]
    },
    {
      "title": "Errettung",
