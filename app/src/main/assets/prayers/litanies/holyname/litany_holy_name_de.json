      "response": "erbarme dich unser.",
      "invocations": [
        {
          "text": "Jesus, Liebhaber der Keuschheit,"
        },
        {
          "text": "Jesus, du unser Liebhaber,"
        },
        {
          "text": "Jesus, Gott des Friedens,"
        },
        {
          "text": "Jesus, Urheber des Lebens,"
        },
        {
          "text": "Jesus, Vorbild der Tugenden,"
        },
        {
