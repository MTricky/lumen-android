{
  "id": "preciousBlood",
  "title": "Litania do Najdroższej Krwi Chrystusa Pana",
  "subtitle": "Cena naszego zbawienia",
  "prayers": {
    "signOfTheCross": {
      "title": "Znak Krzyża",
      "text": "W imię Ojca i Syna, i Ducha Świętego. Amen."
    },
    "closingPrayer": {
      "title": "Modlitwa",
      "text": "Wszechmogący, wieczny Boże, który jednorodzonego Syna swego ustanowiłeś Odkupicielem świata i Krwią Jego dałeś się przebłagać, daj nam, prosimy, godnie czcić cenę naszego zbawienia i dzięki niej doznawać obrony od zła doczesnego na ziemi, abyśmy wiekuistym szczęściem radowali się w niebie. Przez tegoż Chrystusa, Pana naszego. Amen."
    }
  },
